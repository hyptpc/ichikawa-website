/* ベース設定 */
*,
*::before,
*::after {
  box-sizing: border-box;
}

:root {
  --bg-gradient-from: #0f172a;
  --bg-gradient-to:   #020617;
  --card-bg:          #0b1220;
  --accent:           #38bdf8;
  --accent-soft:      rgba(56, 189, 248, 0.2);
  --text-main:        #e5e7eb;
  --text-muted:       #9ca3af;
  --border-subtle:    rgba(148, 163, 184, 0.3);
  --shadow-soft:      0 24px 45px rgba(15, 23, 42, 0.6);
  --radius-lg:        18px;
  --transition-fast:  180ms ease-out;
  --max-width:        960px;
  --spacing:          1.25rem;
  --spacing-lg:       2rem;
  --spacing-xl:       3rem;
  --font-main: system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Text",
               "Segoe UI", sans-serif;
}

html, body {
  margin: 0;
  padding: 0;
  height: 100%;
}

.comment-block * {
  overflow-wrap: break-word;
  word-break: break-word;
}

#recent-comments {
  white-space: pre-wrap;
  overflow-wrap: break-word;
  word-break: break-word;
}


.time-banner {
  margin-top: 10px;
  padding: 0.75rem 1rem;          /* 内側の余白 */
  font-size: 1.4rem;
  font-weight: bold;
  text-align: center;

  /* 改行を有効にする */
  white-space: pre-line;

  /* ダーク背景に合う“塗りつぶし” */
  background: radial-gradient(circle at top, #1f2937, #020617);
  border-radius: 14px;
  border: 1px solid rgba(56, 189, 248, 0.5);  /* 既存のアクセント色系 */
  color: #ff4d4d;

  /* ちょっと浮かせる */
  box-shadow: 0 12px 25px rgba(15, 23, 42, 0.9);
}


body {
  font-family: var(--font-main);
  color: var(--text-main);
  background: radial-gradient(circle at top, #111827 0, #020617 60%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ヘッダー */
.site-header {
  padding: var(--spacing-xl) var(--spacing);
}

.site-header-inner {
  max-width: var(--max-width);
  margin: 0 auto;
}

.site-title {
  margin: 0 0 0.5rem;
  font-size: clamp(1.6rem, 2.3vw + 1rem, 2.4rem);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #e5f3ff;
}

.site-subtitle {
  margin: 0;
  max-width: 640px;
  color: var(--text-muted);
  font-size: 0.95rem;
  line-height: 1.6;
}

/* メイン */
.site-main {
  flex: 1;
  padding: 0 var(--spacing) var(--spacing-xl);
}

.card {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: var(--spacing-lg);
  background: radial-gradient(circle at top left, rgba(56, 189, 248, 0.12), transparent 60%),
              var(--card-bg);
  border-radius: 24px;
  border: 1px solid var(--border-subtle);
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(20px);
}

.card-title {
  margin: 0 0 0.5rem;
  font-size: 1.25rem;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.card-title::before {
  content: "";
  display: inline-block;
  width: 8px;
  height: 8px;
  background: var(--accent);
  border-radius: 999px;
  box-shadow: 0 0 12px rgba(56, 189, 248, 0.7);
}

.card-description {
  margin: 0 0 var(--spacing-lg);
  color: var(--text-muted);
  font-size: 0.92rem;
  line-height: 1.7;
}

/* グラフ：画像版（完全レスポンシブ） */
.chart-wrapper {
  width: 100%;
  max-width: 1000px;
  margin: 0 auto 1.8rem;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: radial-gradient(circle at top, #1f2937, #020617);
  border: 1px solid var(--accent-soft);
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.8);
}

.chart-wrapper img {
  display: block;
  width: 100%;
  height: auto;  /* これで比率を保ったまま縮小 */
  border: none;
}

/* フッター */
.site-footer {
  padding: var(--spacing-lg) var(--spacing) var(--spacing);
  text-align: center;
  font-size: 0.8rem;
  color: var(--text-muted);
}



/* テーブル埋め込み */
.card-subtitle {
  margin: 1.5rem 0 0.3rem;
  font-size: 1.05rem;
  font-weight: 600;
  color: #e5f3ff;
}

.card-description.small {
  margin-bottom: 0.9rem;
  font-size: 0.85rem;
}

.table-block {
  margin-top: 1.8rem;
}

.table-wrapper {
  position: relative;
  width: 100%;
  max-height: 650px;
  border-radius: var(--radius-lg);
  overflow: auto;
  background: #020617;
  border: 1px solid var(--border-subtle);
  box-shadow: 0 16px 32px rgba(15, 23, 42, 0.7);
}


.table-wrapper iframe {
  width: 100%;
  min-height: 650px;
  border: none;
}



/* モバイル調整 */
@media (max-width: 768px) {
  .site-header {
    padding: var(--spacing-lg) var(--spacing);
  }

  .card {
    padding: 1.15rem;
    border-radius: 18px;
  }

  .card-description {
    font-size: 0.9rem;
  }

  .table-wrapper {
    max-height: 360px;
  }
}

@media (max-width: 400px) {
  .site-title {
    font-size: 1.4rem;
  }

  .card {
    padding: 1rem;
  }
}
